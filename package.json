{
  "name": "outsource-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir",
    "preview": "vite preview",
    "deploy": "cross-env DEPLOY_TARGET=gh-pages vite build --emptyOutDir && gh-pages -d build --dest outsource-dashboard",
    "lint": "eslint src",
    "format": "prettier --write src",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "sass": "^1.93.0",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@csstools/normalize.css": "^12.1.1"
  }
}
